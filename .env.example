# Jellyfin connection
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# Where downloaded files land (must also be mounted into Jellyfin as a library path)
DOWNLOAD_DIR=/media/downloads
MOVIES_DIR=/media/Movies
TV_DIR=/media/TV Shows

# Sidecar bind
SIDECAR_HOST=0.0.0.0
SIDECAR_PORT=8765

# Sidecar image. Pin to a specific release (e.g. ghcr.io/itsomidkarami/jellygrab-sidecar:0.2.3)
# rather than :latest if you want stable upgrades. Leave unset to use :latest.
# SIDECAR_IMAGE=ghcr.io/itsomidkarami/jellygrab-sidecar:latest

# 30nama base
NAMA_BASE_URL=https://30nama.com

# 30nama session — login in your browser, then DevTools → Application → Cookies,
# copy the full Cookie header value (e.g. "PHPSESSID=...; cf_clearance=...").
# Sidesteps reCAPTCHA since CAPTCHA only fires on the login form.
NAMA_COOKIE=
# JSON cookie jar persisted by the sidecar and editable from the plugin config page.
NAMA_COOKIES_FILE=/secrets/30nama_cookies.json
# Use the same User-Agent as the browser you logged in with (Cloudflare/cf_clearance is UA-bound).
NAMA_USER_AGENT=

# How often the sidecar pings 30nama to keep the session warm. Set to 0 to disable.
KEEPALIVE_INTERVAL_SEC=1800

# FlareSolverr connection for Cloudflare-backed scraper requests.
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_SESSION=jellygrab
FLARESOLVERR_TIMEOUT_MS=60000

# Host paths (used by docker-compose)
HOST_MEDIA_DIR=./media
